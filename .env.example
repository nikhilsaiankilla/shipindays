# App base URL
APP_URL=http://localhost:3000

# Auth provider to use
# supabase | nextauth
AUTH_PROVIDER=supabase

# Email provider to use
# resend | mailgun
EMAIL_PROVIDER=resend

# Payment provider to use
# stripe | lemon-squeezy
PAYMENT_PROVIDER=stripe


# Stripe secret API key
STRIPE_SECRET=

# Stripe webhook secret for verifying events
STRIPE_WEBHOOK_SECRET=

# Stripe price ID for subscription
STRIPE_PRICE_ID=



# Lemon Squeezy API key
LEMONSQUEEZY_API_KEY=

# Lemon Squeezy webhook secret
LEMONSQUEEZY_WEBHOOK_SECRET=

# Lemon Squeezy variant ID (equivalent to Stripe price ID)
LEMONSQUEEZY_VARIANT_ID=


# Resend API key
RESEND_API_KEY=


# Mailgun API key
MAILGUN_API_KEY=

# Mailgun sending domain
MAILGUN_DOMAIN=


# Google OAuth client ID (NextAuth)
GOOGLE_CLIENT_ID=

# Google OAuth client secret (NextAuth)
GOOGLE_CLIENT_SECRET=

# SMTP server URL for NextAuth email provider
EMAIL_SERVER=

# Sender address for NextAuth email provider
EMAIL_FROM=


# Supabase public URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server URL
SUPABASE_URL=

# Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=
